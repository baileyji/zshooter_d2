    "main.yaml": zfront.calibration_control
    "logger.yaml": present
  }
  status: {
    "lamp_state [rw]": State
    "selector_state [rw]": State
  }
  events: {
    "lamp_fault": Event
  }
  ops: {
    "set_lamp_state(...)"
    "set_selector_state(...)"
    "estop()"
  }
}

