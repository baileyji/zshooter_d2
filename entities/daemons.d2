focus_controller: {
  ...@../common/templates.daemon
  label: "Focus Controller (FocusController)"
  device: suspend
  eng: suspend
  config: {
    "main.yaml": zspec.focus_controller
    "logger.yaml": present
  }
  status: {
    "focus_curve_params [rw*]": CurveSet
    "maintain_focus [rw]": bool
  }
  events: {
    "domain_error": Event
    "set_focus_error": Event
  }
  ops: {
    "get_focus_curve_params()"
    "set_focus_curve_params(...)"
    "start_maintain_focus()"
    "stop_maintain_focus()"
  }
}

focus: {
  ...@../common/templates.daemon
  label: "Focus Drive (FocusDriveDaemon)"
  device: {
    FocusDriveDevice: SerialDevice
  }
  config: {
    "main.yaml": zimage.focus
    "logger.yaml": present
  }
  status: {
    "position [rw]": Position
    "drive_settings [rw]": Settings
  }
  events: {
    "drive_fault": Event
  }
  ops: {
    "get_focus()"
    "set_focus_abs(pos: float)"
    "set_focus_rel(delta: float)"
    "calibrate()"
    "stop_motion()"
    "estop()"
  }
}

vacuum_monitor: {
  ...@../common/templates.daemon
  label: "Vacuum Monitor (VacuumMonitorDaemon)"
  eng: suspend
  device: suspend
  config: {
    "main.yaml": zspec.vacuum_monitor
    "logger.yaml": present
  }
  status: {
    "vacuum_state": State
  }
  events: {
    "range_alert": Event
  }
  ops: {
    "get_vacuum()"
  }
}

fine_guiding: {
  ...@../common/templates.daemon
  device: suspend
