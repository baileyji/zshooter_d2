  }
}


quest2readout: {
  ...@../common/templates.daemon
   label: "Quest2 Readout (ImagerReadoutDaemon)"
   device: {
     Quest2Driver: (CoaXPressDevice)
   }
   config: {
     "main.yaml": zimage.readout_z
     "logger.yaml": present
   }
   status: {
     "exposure_type [rw]": ExposureType
     "exposure_time_s [rw]": float
     "readout_mode [rw]": Mode
   }
   events: {
     "exposure_complete": Event
     "thermal_fault": Event
   }
   ops: {
     "set_exposure_type(kind: ExposureType)"
     "set_exposure_time(t_exp_s: float)"
     "set_readout_mode(mode: ReadoutMode)"
     "start_exposure()"
     "abort_exposure()"
     "stop_exposure()"
   }
}


archonreadout: {
  ...@../common/templates.daemon
  label: "Archon Readout (ReadoutDaemon)"
  device: {
    ArchonDriver: (camerad heritage)
  }
  object_model: unsuspend {
    exposure_config: {
      class: object_block
      label: ExposureConfig
    }
    readout_status: {
      class: object_block
      label: ReadoutStatus
    }
  }
  config: {
    "main.yaml": zspec.readout_opt_b
    "archon/*.wdl": present
    "logger.yaml": present
  }
  status: {
    "exposure_type [rw]": ExposureType
    "exposure_time_s [rw]": float
    "readout_region [rw]": RegionSpec
    "readout_mode [rw]": ReadoutMode
    "gain_mode [rw]": GainMode
    "speed_mode [rw]": SpeedMode
    "binning [rw]": BinSpec
    "amplifier_selection [rw]": AmpSpec
    "detector_temperature": float
    "controller_state": ControllerState
  }
  events: {
    "exposure_complete": Event
    "thermal_fault": Event
  }
  ops: {
    "set_exposure_type(kind: ExposureType)"
    "set_exposure_time(t_exp_s: float)"
    "set_readout_region(region: RegionSpec)"
    "set_readout_format(gain: GainMode, speed: SpeedMode, binning: BinSpec, amps: AmpSpec)"
    "set_readout_mode(mode: ReadoutMode)"
    "start_exposure()"
    "abort_exposure()"
  }
  eng: {
    "set_engineering(param: str, value: Any)"
    "get_engineering(param: str)"
  }
}

temp_monitor: {
  ...@../common/templates.daemon
  eng: suspend
  label: "Temp Monitor (`TempMonitorDaemon`)"
  device: {
    OneWireHubDevice: (MQTT Something)
  }
  config: {
    "main.yaml": zspec.opt_temp_monitor
    "logger.yaml": present
  }
  status: {
    "sensor_state": SensorState
  }
  events: {
    "range_alert": Event
  }
  ops: {
    "get_temperature(...)"
  }
}