motor_controller: {
  ...@../common/templates.daemon
  label: "Generic Motor Bus/Controller ()"
  device: {
    "MotorController": (Somedriver)
  }
  config: {
    "main.yaml": controller
    "logger.yaml": present
  }
  events: {

    "drive_fault": Event
  }
