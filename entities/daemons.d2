rotator: {
  ...@../common/templates.daemon
  label: "Rotator (FieldRotatorDaemon)"
  device: {
    RotatorDevice: (SerialDevice)
  }
  config: {
    "main.yaml": zspec....
    "logger.yaml": present
  }
  status: {
    "field_angle_offset [rw*]": Angle
