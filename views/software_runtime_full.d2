direction: right
...@../common/styles
software_runtime: @../entities/ics.software_runtime
drp_runtime: @../entities/drp.drp_runtime
instrument_telemetry_db: @../entities/common.instrument_telemetry_db
hardware_system: @../entities/zshooter_hardware.hardware_system
...@../models/software_commands
...@../models/software_publishes
...@../models/device_driver_links

hardware_system: {
  (**->**)[*]: suspend
  **: suspend {
    &leaf: true
  }
  **: unsuspend {
  &class: room_container
  }
  **: unsuspend {
    &class: instrument_container
  }
  **: unsuspend {
    &class: subinstrument_container
  }
  **: unsuspend {
    &class: ebox_enclosure_container
  }

  **: suspend {
    &class: daemon_card_container
  }
  **: unsuspend {
    &class: req_software
  }
  **: unsuspend {
    &class: controller_device_node
  }
  **: {
    dcs_*.dewar: suspend
  }
    **: {
    dcs_*.dewar: suspend
  }
}

