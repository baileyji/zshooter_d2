      stroke: "#64748B"
      stroke-width: 1
      font-size: 11
    }
  }

  config_section_block: {
    shape: class
    style: {
      fill: "#FFFFFF"
      stroke: "#475569"
      stroke-width: 1
      font-size: 11
    }
  }

  ops_section_block: {
    shape: class
    style: {
