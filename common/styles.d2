# Shared styles, tags, and connection classes for ZShooter.
templates: {
  daemon: {
    #grid-rows: 3
    class: daemon_card_container
    label: "Daemon Template"
    config: {
      class: config_section_block
      label: Config
    }
    device: {
      class: device_section_container
      label: Device Drivers
    }
    status: {
      class: status_section_block
      label: Status
    }
    events: {
      class: event_section_block
      label: Alerts/Pub
    }
    ops: {
      class: ops_section_block
      label: Commands
    }
    eng: {
      class: eng_section_block
      label: Eng. Cmds
    }
    object_model: suspend {
      class: object_model_container
      label: Object Model
    }
  }
}

classes: {
  req_software

  room_container: {
    shape: rectangle
    style: {
      fill: "#F8FAFC"
      stroke: "#64748B"
      stroke-width: 2
      stroke-dash: 2
      font-size: 14
    }
  }

  instrument_container: {
    shape: rectangle
    style: {
      fill: "#EFF6FF"
      stroke: "#1D4ED8"
      stroke-width: 3
      font-size: 15
    }
  }

  subinstrument_container: {
    shape: rectangle
    style: {
      fill: "#F8FAFC"
      stroke: "#334155"
      stroke-width: 2
      font-size: 14
    }
  }

  enclosure_container: {
    shape: rectangle
    style: {
      fill: "#FFF7ED"
      stroke: "#C2410C"
      stroke-width: 2
      font-size: 13
    }
  }

  cryostat_container: {
