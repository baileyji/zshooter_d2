      stroke-width: 1
      font-size: 10
    }
  }

  data_conn: {
    style: {
      stroke: "#2563EB"
      stroke-width: 2
    }
    label: "Data"
  }

  optional_conn: {
    style.stroke-dash: 3
  }

  network_conn: {
    style: {
