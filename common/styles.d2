    style: {
      fill: "#ECFEFF"
      stroke: "#0F766E"
      stroke-width: 2
      font-size: 13
    }
  }

  computer_host_container: {
    shape: rectangle
    style: {
      fill: "#EEF2FF"
      stroke: "#4338CA"
      stroke-width: 2
      font-size: 13
    }
  }

  entity_wrapper: {
    shape: rectangle
    style: {
      opacity: 0
      stroke-width: 0
      fill: transparent
    }
  }

  utility_node: {
    shape: rectangle
    style: {
      fill: "#E5E7EB"
      stroke: "#6B7280"
      stroke-width: 2
      font-size: 12
    }
  }

  service_node: {
    shape: rectangle
    style: {
      fill: "#FAFAFA"
      stroke: "#6B7280"
      stroke-width: 2
      stroke-dash: 3
      font-size: 12
    }
  }

  device_node: {
    shape: rectangle
    style: {
      fill: "#F3F4F6"
      stroke: "#4B5563"
      stroke-width: 2
      font-size: 12
    }
  }

  optional_node: {
    style.stroke-dash: 3
  }

  detector_device_node: {
    shape: rectangle
    style: {
      fill: "#FCE7F3"
      stroke: "#BE185D"
      stroke-width: 2
      font-size: 12
